# Database - แก้ user/password/dbname ตามเครื่องของคุณ
DATABASE_URL="mysql://root:12345678@localhost:3306/chat_db"

# JWT Secret - ควรเปลี่ยนเป็น Random string ยาวๆ ใน Production
JWT_SECRET="super-secret-jwt-key-change-this-in-production"

# Server
PORT=3001

# Frontend URL (สำหรับ Socket.IO CORS)
CLIENT_URL="http://localhost:5173"
